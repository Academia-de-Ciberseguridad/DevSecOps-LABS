# ============================================================
# DevSecOps Lab - Variables de Entorno
# Modifica estos valores antes de ejecutar install.sh
# ============================================================

# IP del servidor (se detecta automáticamente en install.sh)
SERVER_IP=localhost

# Directorio de datos
DEVSECOPS_HOME=/opt/devsecops-lab
GITLAB_HOME=/opt/devsecops-lab/data/gitlab

# --- GitLab CE ---
GITLAB_ROOT_PASSWORD=DevSecOps2024!
GITLAB_PORT_HTTP=8929
GITLAB_PORT_SSH=2224

# --- SonarQube (SAST) ---
SONAR_PORT=9000
SONAR_JDBC_USERNAME=sonar
SONAR_JDBC_PASSWORD=sonar

# --- OWASP ZAP (DAST) ---
ZAP_PORT=8090

# --- DefectDojo ---
DEFECTDOJO_PORT=8080
DD_ADMIN_PASSWORD=DevSecOps2024!

# --- Juice Shop ---
JUICESHOP_PORT=3000

# --- Grafana ---
GRAFANA_PORT=3001
GF_SECURITY_ADMIN_PASSWORD=DevSecOps2024!

# --- Prometheus ---
PROMETHEUS_PORT=9090
